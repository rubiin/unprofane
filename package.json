{
  "name": "unprofane",
  "version": "1.0.6",
  "description": "Library to detect and redact profane words",
  "keywords": [],
  "homepage": "https://github.com/rubiin/unprofane#readme",
  "bugs": "https://github.com/rubiin/unprofane/issues",
  "license": "MIT",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/unprofane.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@rubiin/tsconfig": "^2.2.0",
    "@types/node": "^24.12.4",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "vitest": {
    "environment": "node",
    "globals": true,
    "include": [
      "tests/**/*.test.ts"
    ],
    "testTimeout": 30000
  }
}
