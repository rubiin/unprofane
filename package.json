{
  "name": "unprofane",
  "version": "1.0.6",
  "description": "Library to detect and redact profane words",
  "keywords": [],
  "homepage": "https://github.com/rubiin/unprofane#readme",
  "bugs": "https://github.com/rubiin/unprofane/issues",
  "license": "MIT",
  "author": "Rubin Bhandari <roobin.bhandari@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubiin/unprofane.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown && copyfiles -f ./src/data/*.json ./dist/data",
    "prepublishOnly": "npm run build",
    "release": "bumpp && clean-publish",
    "test": "jest --config ./tests/jest.config.json",
    "lint": "oxlint --ignore-pattern",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@rubiin/tsconfig": "^2.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.39",
    "bumpp": "^11.0.1",
    "clean-publish": "^7.0.1",
    "copyfiles": "^2.4.1",
    "jest": "29.7.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "prettier": "3.0.3",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "module": "./dist/index.mjs"
}